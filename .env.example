# ============================================================
# GoMiGooo! Environment Variables
# Copy this file to .env.local and fill in your values.
# Only the 3 Supabase variables are REQUIRED before first deploy.
# Everything else can be configured from the Admin Settings UI.
# ============================================================

# ------ REQUIRED: Supabase (get from supabase.com → Project Settings → API) ------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------ OPTIONAL: Configure these from Admin Settings UI after first deploy ------

# Razorpay (https://dashboard.razorpay.com → Settings → API Keys)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Anthropic (https://console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (https://resend.com → API Keys)
RESEND_API_KEY=re_...

# App URL (set to your Vercel deployment URL)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
